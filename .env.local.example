# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your app's public URL (used for auth email redirects)
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps Platform — for address autocomplete on project forms.
# Enable: Maps JavaScript API + Places API (New). Restrict to your domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
